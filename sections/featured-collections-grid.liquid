{% if request.page_type == 'index' %}
  <section class="featured-collections-grid section section--page-width">
    <div class="featured-collections-grid__inner">
      {% if section.settings.heading != blank %}
        <h2 class="featured-collections-grid__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="featured-collections-grid__subheading">{{ section.settings.subheading }}</p>
      {% endif %}

      <div class="featured-collections-grid__cards">
        {% for block in section.blocks %}
          {% assign collection_resource = block.settings.collection %}
          {% assign fallback_product = blank %}
          {% assign collection_image = blank %}

          {% if collection_resource %}
            {% assign collection_image = collection_resource.image %}
            {% if collection_image == blank %}
              {% assign fallback_product = collection_resource.products.first %}
              {% if fallback_product and fallback_product.featured_image %}
                {% assign collection_image = fallback_product.featured_image %}
              {% endif %}
            {% endif %}
          {% endif %}

          <article class="featured-collections-grid__card" {{ block.shopify_attributes }}>
            {% if collection_resource %}
              <a class="featured-collections-grid__image-link" href="{{ collection_resource.url }}">
                {% if collection_image %}
                  {{ collection_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: collection_resource.title, class: 'featured-collections-grid__image' }}
                {% else %}
                  <div class="featured-collections-grid__image featured-collections-grid__image--placeholder"></div>
                {% endif %}
              </a>

              <div class="featured-collections-grid__content">
                <h3 class="featured-collections-grid__title">{{ collection_resource.title }}</h3>
                <p class="featured-collections-grid__count">{{ collection_resource.products_count }} products</p>
                <a class="featured-collections-grid__button" href="{{ collection_resource.url }}">
                  {{ block.settings.button_text | default: 'Shop Now' }}
                </a>
              </div>
            {% else %}
              <div class="featured-collections-grid__image featured-collections-grid__image--placeholder"></div>
              <div class="featured-collections-grid__content">
                <h3 class="featured-collections-grid__title">Select a collection</h3>
                <p class="featured-collections-grid__count">0 products</p>
                <span class="featured-collections-grid__button">{{ block.settings.button_text | default: 'Shop Now' }}</span>
              </div>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    </div>
  </section>
{% endif %}

{% stylesheet %}
  .featured-collections-grid__inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .featured-collections-grid__heading {
    margin: 0 0 8px;
  }

  .featured-collections-grid__subheading {
    margin: 0 0 20px;
    opacity: 0.8;
  }

  .featured-collections-grid__cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .featured-collections-grid__card {
    border: 1px solid rgb(var(--color-border-rgb));
    border-radius: 10px;
    overflow: hidden;
    background: rgb(var(--color-background-rgb));
  }

  .featured-collections-grid__image-link {
    display: block;
  }

  .featured-collections-grid__image {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .featured-collections-grid__image--placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: linear-gradient(135deg, rgb(var(--color-border-rgb) / 40%), rgb(var(--color-border-rgb) / 20%));
  }

  .featured-collections-grid__content {
    padding: 16px;
  }

  .featured-collections-grid__title {
    margin: 0 0 6px;
  }

  .featured-collections-grid__count {
    margin: 0 0 12px;
    opacity: 0.75;
  }

  .featured-collections-grid__button {
    display: inline-block;
    text-decoration: underline;
    font-weight: 600;
  }

  @media (min-width: 600px) {
    .featured-collections-grid__cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 900px) {
    .featured-collections-grid__cards {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured Collections Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Collections"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Shop top categories chosen for this season"
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "Shop Now"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Featured Collections Grid",
      "blocks": [
        {
          "type": "collection_card"
        },
        {
          "type": "collection_card"
        },
        {
          "type": "collection_card"
        }
      ]
    }
  ]
}
{% endschema %}
