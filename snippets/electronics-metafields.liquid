{% assign has_warranty = product.metafields.custom.warranty_months.value %}
{% assign has_terms = product.metafields.custom.warranty_terms.value %}
{% assign has_spec = product.metafields.custom.spec_sheet.value %}
{% assign has_energy = product.metafields.custom.energy_rating.value %}
{% assign has_year = product.metafields.custom.release_year.value %}
{% assign is_refurbished = product.metafields.custom.is_refurbished.value %}

{% assign badge_only = badge_only | default: false %}
{% assign content_only = content_only | default: false %}

{% if has_warranty or has_terms or has_spec or has_energy or has_year or is_refurbished %}

  {% if is_refurbished == true and content_only != true %}
    <span
      class="refurbished-badge"
      style="display:inline-flex;align-items:center;gap:6px;background:#ed8936;color:#fff;padding:6px 14px;border-radius:999px;font-size:12px;font-weight:700;letter-spacing:.03em;text-transform:uppercase;box-shadow:0 6px 18px rgba(237,137,54,.35);"
    >
      Certified Refurbished
    </span>
  {% endif %}

  {% unless badge_only %}
    {% if has_energy %}
      {% assign energy_rating = has_energy | json | strip %}
      {% if energy_rating contains ',' %}
        {% assign energy_rating = energy_rating | split: ',' | first %}
      {% endif %}
      {% assign energy_rating = energy_rating | replace: '[', '' | replace: ']', '' | replace: '"', '' | strip | upcase %}
      {% assign energy_color = '#e53e3e' %}
      {% assign energy_label = 'Below Average' %}
      {% case energy_rating %}
        {% when 'A++' %}
          {% assign energy_color = '#38a169' %}
          {% assign energy_label = 'Excellent Efficiency' %}
        {% when 'A+' %}
          {% assign energy_color = '#68d391' %}
          {% assign energy_label = 'Very Good Efficiency' %}
        {% when 'A' %}
          {% assign energy_color = '#ecc94b' %}
          {% assign energy_label = 'Good Efficiency' %}
        {% when 'B' %}
          {% assign energy_color = '#ed8936' %}
          {% assign energy_label = 'Average Efficiency' %}
      {% endcase %}
    {% endif %}

    {% assign has_any_spec_row = false %}
    {% if has_warranty or has_year or has_energy %}
      {% assign has_any_spec_row = true %}
    {% endif %}

    <div class="electronics-metafields" style="margin-top:1.25rem;padding:18px;border:1px solid rgba(148,163,184,.25);border-radius:12px;background:rgba(17,24,39,.55);backdrop-filter:blur(2px);">
      <h3 style="margin:0 0 12px;font-size:16px;font-weight:700;color:#f8fafc;">Product Insights</h3>

      {% if has_any_spec_row %}
        <table style="width:100%;border-collapse:collapse;font-size:14px;margin-bottom:14px;">
          <tbody>
            {% if has_warranty %}
              <tr style="border-bottom:1px solid rgba(148,163,184,.22);">
                <td style="padding:10px 12px;color:#cbd5e1;font-weight:500;width:38%;background:rgba(30,41,59,.5);">Warranty</td>
                <td style="padding:10px 12px;color:#f8fafc;font-weight:600;">{{ has_warranty }} months</td>
              </tr>
            {% endif %}

            {% if has_year %}
              <tr style="border-bottom:1px solid rgba(148,163,184,.22);">
                <td style="padding:10px 12px;color:#cbd5e1;font-weight:500;background:rgba(30,41,59,.5);">Release Year</td>
                <td style="padding:10px 12px;color:#f8fafc;font-weight:600;">{{ has_year }}</td>
              </tr>
            {% endif %}

            {% if has_energy %}
              <tr style="border-bottom:1px solid rgba(148,163,184,.22);">
                <td style="padding:10px 12px;color:#cbd5e1;font-weight:500;background:rgba(30,41,59,.5);">Energy Rating</td>
                <td style="padding:10px 12px;color:#f8fafc;font-weight:600;">
                  <span style="display:inline-flex;align-items:center;gap:8px;">
                    <span style="display:inline-block;min-width:40px;text-align:center;padding:4px 10px;border-radius:999px;background:{{ energy_color }};color:#fff;font-size:12px;font-weight:700;">{{ energy_rating }}</span>
                    <span style="font-size:13px;color:{{ energy_color }};font-weight:600;">{{ energy_label }}</span>
                  </span>
                </td>
              </tr>
            {% endif %}
          </tbody>
        </table>
      {% endif %}

      {% if has_terms %}
        <div class="warranty-terms" style="margin-bottom:12px;padding:12px;border:1px solid rgba(148,163,184,.2);border-radius:8px;background:rgba(15,23,42,.45);">
          <h4 style="margin:0 0 8px;font-size:14px;color:#e2e8f0;">Warranty Terms</h4>
          <div style="font-size:14px;line-height:1.65;color:#cbd5e1;">
            {{ product.metafields.custom.warranty_terms | metafield_tag }}
          </div>
        </div>
      {% endif %}

      {% if has_spec %}
        <a
          href="{{ has_spec.url }}"
          target="_blank"
          download
          style="display:inline-flex;align-items:center;gap:8px;background:#1d4ed8;color:#fff;font-size:13px;font-weight:600;padding:10px 14px;border-radius:8px;text-decoration:none;"
        >
          Download Specification Sheet (PDF)
        </a>
      {% endif %}
    </div>
  {% endunless %}

{% endif %}
