{% assign handles_csv = '' %}

{% if product_handles != blank %}
  {% assign handles_csv = product_handles | replace: ' ', '' %}
{% elsif collection and collection.products_count > 1 %}
  {% for cp in collection.products limit: 4 %}
    {% assign handles_csv = handles_csv | append: cp.handle %}
    {% unless forloop.last %}{% assign handles_csv = handles_csv | append: ',' %}{% endunless %}
  {% endfor %}
{% elsif product and product.collections.size > 0 %}
  {% assign best_collection = blank %}
  {% assign best_count = 0 %}
  {% for c in product.collections %}
    {% if c.products_count > best_count %}
      {% assign best_collection = c %}
      {% assign best_count = c.products_count %}
    {% endif %}
  {% endfor %}

  {% if best_collection and best_collection.products_count > 1 %}
    {% for cp in best_collection.products limit: 4 %}
      {% assign handles_csv = handles_csv | append: cp.handle %}
      {% unless forloop.last %}{% assign handles_csv = handles_csv | append: ',' %}{% endunless %}
    {% endfor %}
  {% endif %}
{% endif %}

{% if handles_csv != blank %}
  {% assign compare_handles = handles_csv | split: ',' %}
  {% assign compare_count = 0 %}

  {% for h in compare_handles %}
    {% assign hp = all_products[h] %}
    {% if hp %}
      {% assign compare_count = compare_count | plus: 1 %}
    {% endif %}
  {% endfor %}

  {% if compare_count > 1 %}
    {% assign best_warranty = -1 %}
    {% assign best_energy_score = 99 %}

    {% for h in compare_handles %}
      {% assign p = all_products[h] %}
      {% if p %}
        {% assign w = p.metafields.custom.warranty_months.value %}
        {% if w != blank and w > best_warranty %}
          {% assign best_warranty = w %}
        {% endif %}

        {% assign energy_raw = p.metafields.custom.energy_rating.value %}
        {% if energy_raw != blank %}
          {% assign energy_clean = energy_raw | json | replace: '[', '' | replace: ']', '' | replace: '"', '' | split: ',' | first | strip | upcase %}
          {% assign score = 5 %}
          {% case energy_clean %}
            {% when 'A++' %}{% assign score = 1 %}
            {% when 'A+' %}{% assign score = 2 %}
            {% when 'A' %}{% assign score = 3 %}
            {% when 'B' %}{% assign score = 4 %}
          {% endcase %}
          {% if score < best_energy_score %}
            {% assign best_energy_score = score %}
          {% endif %}
        {% endif %}
      {% endif %}
    {% endfor %}

    <div class="product-compare-specs" style="margin-top:2rem;padding:18px;border:1px solid rgba(148,163,184,.25);border-radius:12px;background:rgba(15,23,42,.45);overflow-x:auto;">
      <h3 style="margin:0 0 12px;color:#f8fafc;font-size:16px;">Quick Compare</h3>
      <table style="width:100%;border-collapse:collapse;min-width:700px;">
        <thead>
          <tr>
            <th style="text-align:left;padding:10px 12px;border-bottom:1px solid rgba(148,163,184,.3);color:#cbd5e1;background:rgba(30,41,59,.5);">Specification</th>
            {% for h in compare_handles %}
              {% assign p = all_products[h] %}
              {% if p %}
                <th style="text-align:left;padding:10px 12px;border-bottom:1px solid rgba(148,163,184,.3);color:#f8fafc;">{{ p.title }}</th>
              {% endif %}
            {% endfor %}
          </tr>
        </thead>
        <tbody>
          <tr>
            <td style="padding:10px 12px;color:#cbd5e1;background:rgba(30,41,59,.5);font-weight:600;">Warranty</td>
            {% for h in compare_handles %}
              {% assign p = all_products[h] %}
              {% if p %}
                {% assign w = p.metafields.custom.warranty_months.value %}
                {% assign is_best_warranty = false %}
                {% if w != blank and w == best_warranty and best_warranty >= 0 %}
                  {% assign is_best_warranty = true %}
                {% endif %}
                <td style="padding:10px 12px;color:#f8fafc;{% if is_best_warranty %}background:rgba(56,161,105,.2);{% endif %}">
                  {% if w != blank %}{{ w }} months{% else %}&mdash;{% endif %}
                </td>
              {% endif %}
            {% endfor %}
          </tr>

          <tr>
            <td style="padding:10px 12px;color:#cbd5e1;background:rgba(30,41,59,.5);font-weight:600;">Energy</td>
            {% for h in compare_handles %}
              {% assign p = all_products[h] %}
              {% if p %}
                {% assign energy_raw = p.metafields.custom.energy_rating.value %}
                {% assign energy_clean = '' %}
                {% assign score = 99 %}
                {% if energy_raw != blank %}
                  {% assign energy_clean = energy_raw | json | replace: '[', '' | replace: ']', '' | replace: '"', '' | split: ',' | first | strip | upcase %}
                  {% assign score = 5 %}
                  {% case energy_clean %}
                    {% when 'A++' %}{% assign score = 1 %}
                    {% when 'A+' %}{% assign score = 2 %}
                    {% when 'A' %}{% assign score = 3 %}
                    {% when 'B' %}{% assign score = 4 %}
                  {% endcase %}
                {% endif %}

                <td style="padding:10px 12px;color:#f8fafc;{% if score == best_energy_score and score < 99 %}background:rgba(56,161,105,.2);{% endif %}">
                  {% if energy_clean != blank %}{{ energy_clean }}{% else %}&mdash;{% endif %}
                </td>
              {% endif %}
            {% endfor %}
          </tr>

          <tr>
            <td style="padding:10px 12px;color:#cbd5e1;background:rgba(30,41,59,.5);font-weight:600;">Year</td>
            {% for h in compare_handles %}
              {% assign p = all_products[h] %}
              {% if p %}
                {% assign y = p.metafields.custom.release_year.value %}
                <td style="padding:10px 12px;color:#f8fafc;">{% if y != blank %}{{ y }}{% else %}&mdash;{% endif %}</td>
              {% endif %}
            {% endfor %}
          </tr>

          <tr>
            <td style="padding:10px 12px;color:#cbd5e1;background:rgba(30,41,59,.5);font-weight:600;">Refurbished</td>
            {% for h in compare_handles %}
              {% assign p = all_products[h] %}
              {% if p %}
                {% assign ref = p.metafields.custom.is_refurbished.value %}
                <td style="padding:10px 12px;color:#f8fafc;">
                  {% if ref == true %}Yes{% elsif ref == false %}No{% else %}&mdash;{% endif %}
                </td>
              {% endif %}
            {% endfor %}
          </tr>
        </tbody>
      </table>
    </div>
  {% endif %}
{% endif %}
